# Frontier GoWild Searcher Environment Variables
# Copy this file to .env and fill in your values

# Slack Configuration (optional - can use config.json instead)
SLACK_CHANNEL=@brett
SLACK_WEBHOOK_URL=

# Search Configuration
ORIGIN_AIRPORT=SLC
SEARCH_TIMEZONE=America/Denver

# Browser Configuration (for Puppeteer)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
PUPPETEER_EXECUTABLE_PATH=

# Logging
LOG_LEVEL=info
